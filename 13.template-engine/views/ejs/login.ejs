<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcom to EJS</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <!-- Main Content -->
    <div class="container">
        <div class="card">
            <h1 class="typing">Welcome to EJS Login</h1>
            <form action="submit-login" method="post" class="matrix-form">
                <div class="form-group">
                    <label for="email">> Enter Email:</label>
                    <input type="email" id="email" name="email" required placeholder="Type your email...">
                </div>
                <div class="form-group">
                    <label for="password">> Enter Password:</label>
                    <input type="password" id="password" name="password" required placeholder="Type your password...">
                </div>
                <button type="submit">Login</button>
            </form>
        </div>
    </div>

</body>

</html>