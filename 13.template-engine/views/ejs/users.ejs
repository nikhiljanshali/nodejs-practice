<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User fa-list</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <div class="container">
        <div class="card">
            <h2 class="typing">User List!</h2>
            <ul>
                <% users.forEach(user=> { %>
                    <li>
                        <%= user.name %> - <%= user.email %>
                    </li>
                <% }); %>
            </ul>
            <button onclick="window.history.back()">↩ Go Back</button>
        </div>
    </div>
</body>

</html>