<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>User Profile</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card shadow">
                    <div class="card-body text-center">
                        <img src="https://via.placeholder.com/150" class="rounded-circle mb-3" alt="Profile Picture">
                        <h2 class="card-title">John Doe</h2>
                        <p class="text-muted">Senior Software Engineer</p>
                        <hr>
                        <div class="text-start">
                            <p><strong>Email:</strong> john.doe@example.com</p>
                            <p><strong>Location:</strong> San Francisco, CA</p>
                            <p><strong>Bio:</strong> Dedicated professional with over 10 years of experience in
                                full-stack development and system architecture.</p>
                        </div>
                        <button class="btn btn-primary w-100 mt-3" onclick="window.location.href='/'">back to Home</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</body>

</html>