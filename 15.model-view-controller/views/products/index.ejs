<%- include('../partials/header') %>

<div class="page-header">
  <h1>Products <span class="badge"><%= products.length %></span></h1>
  <a href="/products/new" class="btn btn-primary">+ New Product</a>
</div>

<% if (products.length === 0) { %>
  <div class="empty-state">
    <p>No products yet. <a href="/products/new">Add the first one →</a></p>
  </div>
<% } else { %>
  <table class="table">
    <thead>
      <tr>
        <th>#</th>
        <th>Name</th>
        <th>Category</th>
        <th>Price</th>
        <th>Stock</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% products.forEach(product => { %>
        <tr>
          <td class="muted"><%= product.id %></td>
          <td><strong><%= product.name %></strong></td>
          <td><span class="tag"><%= product.category %></span></td>
          <td>$<%= product.price.toFixed(2) %></td>
          <td class="<%= product.stock < 10 ? 'low-stock' : '' %>">
            <%= product.stock %> units
          </td>
          <td class="actions">
            <a href="/products/<%= product.id %>" class="btn btn-sm">View</a>
            <a href="/products/<%= product.id %>/edit" class="btn btn-sm btn-secondary">Edit</a>
            <form action="/products/<%= product.id %>?_method=DELETE" method="POST" style="display:inline">
              <button type="submit" class="btn btn-sm btn-danger"
                onclick="return confirm('Delete this product?')">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>

<%- include('../partials/footer') %>
