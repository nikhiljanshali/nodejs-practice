<%- include('../partials/header') %>

<div class="page-header">
  <a href="/products" class="back-link">← All Products</a>
  <h1><%= title %></h1>
</div>

<% if (typeof error !== 'undefined') { %>
  <div class="alert alert-error"><%= error %></div>
<% } %>

<div class="card form-card">
  <form action="<%= action %>" method="POST">

    <div class="form-group">
      <label for="name">Product Name</label>
      <input
        type="text"
        id="name"
        name="name"
        class="input"
        placeholder="e.g. Mechanical Keyboard"
        value="<%= product ? product.name : '' %>"
        required
      />
    </div>

    <div class="form-group">
      <label for="category">Category</label>
      <select id="category" name="category" class="input" required>
        <option value="">— Select a category —</option>
        <% ['Electronics', 'Furniture', 'Clothing', 'Books', 'Other'].forEach(cat => { %>
          <option value="<%= cat %>"
            <%= (product && product.category === cat) ? 'selected' : '' %>>
            <%= cat %>
          </option>
        <% }) %>
      </select>
    </div>

    <div class="form-row">
      <div class="form-group">
        <label for="price">Price ($)</label>
        <input
          type="number"
          id="price"
          name="price"
          class="input"
          placeholder="0.00"
          step="0.01"
          min="0"
          value="<%= product ? product.price : '' %>"
          required
        />
      </div>

      <div class="form-group">
        <label for="stock">Stock Units</label>
        <input
          type="number"
          id="stock"
          name="stock"
          class="input"
          placeholder="0"
          min="0"
          value="<%= product ? product.stock : '' %>"
          required
        />
      </div>
    </div>

    <div class="form-actions">
      <a href="/products" class="btn btn-ghost">Cancel</a>
      <button type="submit" class="btn btn-primary">
        <%= product ? '💾 Save Changes' : '✅ Create Product' %>
      </button>
    </div>

  </form>
</div>

<%- include('../partials/footer') %>
