<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Compose Email</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">
    <div class="container mt-5">
        <div class="card shadow-sm mx-auto" style="max-width: 600px;">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Compose New Message</h5>
            </div>
            <div class="card-body">
                <form id="emailForm" action="/send-mail" method="POST">
                    <div class="mb-3">
                        <label for="from" class="form-label">To</label>
                        <input type="email" name="to" class="form-control" id="from" placeholder="sender@example.com">
                    </div>
                    <div class="mb-3">
                        <label for="to" class="form-label">Subject</label>
                        <input type="text" name="subject" class="form-control" id="to" placeholder="Email subject">
                    </div>
                    <div class="mb-3">
                        <label for="message" class="form-label">Message</label>
                        <textarea class="form-control" name="message" id="message" rows="5"
                            placeholder="Enter your message here..."></textarea>
                    </div>
                    <div class="d-grid">
                        <button type="submit" class="btn btn-primary">Send Email</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</body>

</html>