<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 - Not Found</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>

    <div class="container">

        <!-- Header -->
        <h1 class="typing">404 ERROR</h1>

        <!-- Card -->
        <div class="card" style="text-align:center;">

            <h2>⚠ SYSTEM FAILURE</h2>

            <p>The page you are looking for does not exist in the system.</p>
            <p class="danger">Access Denied / Broken Route</p>

            <br>

            <p>> Redirecting is recommended...</p>

            <br>

            <!-- Buttons -->
            <div style="display:flex; justify-content:center; gap:15px; flex-wrap:wrap;">
                <a href="/" style="text-decoration:none;">
                    <button>⬅ Go Home</button>
                </a>

                <button onclick="window.history.back()">↩ Go Back</button>
            </div>

        </div>

        <!-- Footer -->
        <div style="text-align:center; margin-top:20px; opacity:0.7;">
            <p>System Log: Page not found | Status Code: 404</p>
        </div>

    </div>

</body>

</html>